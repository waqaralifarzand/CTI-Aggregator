# Database (SQLite default, swap for PostgreSQL in production)
DATABASE_URL=sqlite:///./cti_aggregator.db

# AlienVault OTX (free key from https://otx.alienvault.com)
OTX_API_KEY=your_otx_api_key_here

# MISP Instance (optional, leave blank to skip)
MISP_URL=https://your-misp-instance.org
MISP_API_KEY=your_misp_api_key_here
MISP_VERIFY_SSL=true

# Application
CORS_ORIGINS=["http://localhost:5173"]
LOG_LEVEL=INFO

# ML
MODEL_PATH=backend/ml/models/rf_severity_model.joblib
RF_N_ESTIMATORS=200
RF_MAX_DEPTH=15

# Rate Limits (requests per minute)
OTX_RATE_LIMIT=30
URLHAUS_RATE_LIMIT=60
MALWAREBAZAAR_RATE_LIMIT=60
MISP_RATE_LIMIT=30
